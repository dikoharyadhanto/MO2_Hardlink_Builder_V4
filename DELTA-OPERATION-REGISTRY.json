{
  "schema_version": "1.1.0",
  "operations": [
    {
      "operation_id": "project_start",
      "domain": "project",
      "action": "start",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Initialize a new Delta project structure or resume a closed one. Auto-detects name from directory.",
      "inputs": [],
      "outputs": [
        { "name": "project_json", "type": "document" },
        { "name": "progress_json", "type": "document" }
      ],
      "constraints": [],
      "gating": { "pre_condition": null, "post_condition": "project is active" }
    },
    {
      "operation_id": "project_end",
      "domain": "project",
      "action": "end",
      "level": "semantic",
      "role": "any",
      "mode": "strict",
      "description": "Close a Delta project. Hard-gated by locked PDC.",
      "inputs": [],
      "outputs": [
        { "name": "project_json_update", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "PDC must be LOCKED OR override declared" },
        { "type": "block_gate", "rule": "No active cascade block permitted" }
      ],
      "gating": {
        "pre_condition": "workflow_state.pdc_locked == true",
        "post_condition": "project is closed"
      }
    },
    {
      "operation_id": "project_status",
      "domain": "project",
      "action": "status",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "Show project identity and current state from project.json.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": "project.json exists", "post_condition": null }
    },
    {
      "operation_id": "project_list",
      "domain": "project",
      "action": "list",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "List all Delta projects from the global project registry at ~/.delta/project_registry.json.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": null, "post_condition": null }
    },
    {
      "operation_id": "project_refresh",
      "domain": "project",
      "action": "refresh",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Cross-check project_registry.json against filesystem and update stale entries.",
      "inputs": [],
      "outputs": [
        { "name": "project_registry", "type": "document" }
      ],
      "constraints": [],
      "gating": { "pre_condition": null, "post_condition": "registry is consistent with filesystem" }
    },
    {
      "operation_id": "project_archive",
      "domain": "project",
      "action": "archive",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Mark a project as archived. Optionally move to external archive directory.",
      "inputs": [],
      "outputs": [
        { "name": "project_json_update", "type": "state_transition" }
      ],
      "constraints": [],
      "gating": { "pre_condition": "project is closed or active", "post_condition": "project.status == archived" }
    },
    {
      "operation_id": "project_update",
      "domain": "project",
      "action": "update",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Update an existing Delta project to latest structure (add missing folders, refresh templates).",
      "inputs": [],
      "outputs": [
        { "name": "delta_folders", "type": "document" }
      ],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": "project structure is current" }
    },
    {
      "operation_id": "session_bootstrap",
      "domain": "session",
      "action": "bootstrap",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "Load runtime state and surface alerts: phase, STRAT lock, WO state, active overrides, active cascade blocks. Must run at session start.",
      "inputs": [],
      "outputs": [
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": null }
    },
    {
      "operation_id": "session_close",
      "domain": "session",
      "action": "close",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Finalize session and update progress.json gate log.",
      "inputs": [],
      "outputs": [
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [],
      "gating": { "pre_condition": null, "post_condition": null }
    },
    {
      "operation_id": "di_new",
      "domain": "di",
      "action": "new",
      "level": "semantic",
      "role": "director",
      "mode": "strict",
      "description": "Create a new Director's Intent document. Injects DI template. Auto-generates filename if --file omitted.",
      "inputs": [],
      "outputs": [
        { "name": "di_document", "type": "document" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": null, "post_condition": "DI is PENDING" }
    },
    {
      "operation_id": "di_complete",
      "domain": "di",
      "action": "complete",
      "level": "semantic",
      "role": "director",
      "mode": "strict",
      "description": "Mark DI as COMPLETE. Prerequisite for DI lock.",
      "inputs": [],
      "outputs": [
        { "name": "di_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "DI must be PENDING" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "DI is PENDING", "post_condition": "DI is COMPLETE" }
    },
    {
      "operation_id": "di_lock",
      "domain": "di",
      "action": "lock",
      "level": "semantic",
      "role": "director",
      "mode": "strict",
      "description": "Lock DI — finalizes Director Intent. Hard gate: STRAT creation blocked until DI is locked. Requires Director audit approval.",
      "inputs": [],
      "outputs": [
        { "name": "di_locked_state", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "DI must be COMPLETE" },
        { "type": "audit_policy", "rule": "Director must be in approved_by" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": {
        "pre_condition": "DI is COMPLETE AND Director approved",
        "post_condition": "DI is LOCKED; workflow_state.di_locked == true; strat new gate opens"
      }
    },
    {
      "operation_id": "strat_new",
      "domain": "strat",
      "action": "new",
      "level": "semantic",
      "role": "gmn",
      "mode": "strict",
      "description": "Create a new STRAT document. Gate: DI must be locked.",
      "inputs": [],
      "outputs": [
        { "name": "strat_document", "type": "document" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "workflow_state.di_locked == true OR strat_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "DI is LOCKED", "post_condition": "STRAT is PENDING" }
    },
    {
      "operation_id": "strat_complete",
      "domain": "strat",
      "action": "complete",
      "level": "semantic",
      "role": "gmn",
      "mode": "strict",
      "description": "Mark STRAT as COMPLETE. Prerequisite for STRAT lock.",
      "inputs": [],
      "outputs": [
        { "name": "strat_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STRAT must be PENDING or IN_PROGRESS" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "STRAT is PENDING or IN_PROGRESS", "post_condition": "STRAT is COMPLETE" }
    },
    {
      "operation_id": "strat_lock",
      "domain": "strat",
      "action": "lock",
      "level": "semantic",
      "role": "gmn",
      "mode": "strict",
      "description": "Lock STRAT — prevents changes without STRAT_INVALIDATION. Requires audit policy satisfied. Opens wo new gate.",
      "inputs": [],
      "outputs": [
        { "name": "strat_locked_state", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STRAT must be COMPLETE" },
        { "type": "audit_policy", "rule": "Audit policy for strat must be satisfied OR audit_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": {
        "pre_condition": "STRAT is COMPLETE AND audit policy satisfied",
        "post_condition": "STRAT is LOCKED; workflow_state.strat_locked == true; wo new gate opens"
      }
    },
    {
      "operation_id": "strat_pivot",
      "domain": "strat",
      "action": "pivot",
      "level": "semantic",
      "role": "gmn",
      "mode": "strict",
      "description": "Unlock STRAT for revision after a STRAT_INVALIDATION. Resets strat_locked, phase to strategy.",
      "inputs": [],
      "outputs": [
        { "name": "strat_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STRAT must currently be locked" }
      ],
      "gating": {
        "pre_condition": "workflow_state.strat_locked == true",
        "post_condition": "STRAT is IN_PROGRESS; strat_locked reset to false"
      }
    },
    {
      "operation_id": "strat_sync_version",
      "domain": "strat",
      "action": "sync_version",
      "level": "semantic",
      "role": "any",
      "mode": "any",
      "description": "Sync workflow_state.active_strat_version from the STRAT runtime entry. Corrects drift.",
      "inputs": [],
      "outputs": [
        { "name": "workflow_state_update", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [],
      "gating": { "pre_condition": "STRAT document exists in document_states", "post_condition": "active_strat_version is synced" }
    },
    {
      "operation_id": "wo_new",
      "domain": "wo",
      "action": "new",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Create a new Work Order. Gate: STRAT must be locked. Prior WO must be null, COMPLETE, SUPERSEDED, or PENDING (PENDING triggers version look-back to last completed baseline).",
      "inputs": [],
      "outputs": [
        { "name": "wo_document", "type": "document" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "workflow_state.strat_locked == true OR strat_gate override active" },
        { "type": "gate", "rule": "active_wo_state must be null, COMPLETE, SUPERSEDED, or PENDING OR wo_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "STRAT is LOCKED", "post_condition": "WO is PENDING" }
    },
    {
      "operation_id": "wo_advance",
      "domain": "wo",
      "action": "advance",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Transition WO from PENDING to IN_PROGRESS.",
      "inputs": [],
      "outputs": [
        { "name": "wo_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be PENDING" }
      ],
      "gating": { "pre_condition": "WO is PENDING", "post_condition": "WO is IN_PROGRESS" }
    },
    {
      "operation_id": "wo_complete",
      "domain": "wo",
      "action": "complete",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Transition WO from IN_PROGRESS to COMPLETE.",
      "inputs": [],
      "outputs": [
        { "name": "wo_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be IN_PROGRESS" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "WO is IN_PROGRESS", "post_condition": "WO is COMPLETE" }
    },
    {
      "operation_id": "wo_lock",
      "domain": "wo",
      "action": "lock",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Lock a COMPLETE WO. Opens impl new and str new gates at the same version.",
      "inputs": [],
      "outputs": [
        { "name": "wo_locked_state", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be COMPLETE" },
        { "type": "gate", "rule": "STRAT must be locked" },
        { "type": "audit_policy", "rule": "Audit policy for wo must be satisfied OR audit_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": {
        "pre_condition": "WO is COMPLETE AND STRAT is LOCKED AND audit satisfied",
        "post_condition": "WO is LOCKED; str new and impl new gates open for same version"
      }
    },
    {
      "operation_id": "wo_pause",
      "domain": "wo",
      "action": "pause",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Pause WO execution: IN_PROGRESS → BLOCKED (execution pause only, not cascade quarantine). Use 'delta block' for cascade quarantine.",
      "inputs": [
        { "name": "reason", "source": "option", "required": true }
      ],
      "outputs": [
        { "name": "wo_state_entry", "type": "state_transition" },
        { "name": "block_reason_entry", "type": "log_entry" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be IN_PROGRESS" }
      ],
      "gating": { "pre_condition": "WO is IN_PROGRESS", "post_condition": "WO is BLOCKED (paused)" }
    },
    {
      "operation_id": "wo_resume",
      "domain": "wo",
      "action": "resume",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Resume a paused WO: BLOCKED → IN_PROGRESS. Records block history.",
      "inputs": [],
      "outputs": [
        { "name": "wo_state_entry", "type": "state_transition" },
        { "name": "block_history_entry", "type": "log_entry" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be BLOCKED" }
      ],
      "gating": { "pre_condition": "WO is BLOCKED", "post_condition": "WO is IN_PROGRESS" }
    },
    {
      "operation_id": "wo_supersede",
      "domain": "wo",
      "action": "supersede",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Mark active WO as SUPERSEDED and register a replacement WO.",
      "inputs": [
        { "name": "new_file", "source": "option", "required": true }
      ],
      "outputs": [
        { "name": "wo_state_entry", "type": "state_transition" },
        { "name": "new_wo_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "An active WO must exist" }
      ],
      "gating": { "pre_condition": "active WO exists", "post_condition": "old WO is SUPERSEDED; new WO is PENDING" }
    },
    {
      "operation_id": "wo_status",
      "domain": "wo",
      "action": "status",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "Show active WO state, phase, and execution mode.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": null }
    },
    {
      "operation_id": "wo_list",
      "domain": "wo",
      "action": "list",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "List all registered WOs and their lifecycle states.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": null }
    },
    {
      "operation_id": "str_new",
      "domain": "str",
      "action": "new",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Create a new ANT-STR document. Gate: WO must be LOCKED.",
      "inputs": [],
      "outputs": [
        { "name": "str_document", "type": "document" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO must be LOCKED OR strat_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "WO is LOCKED", "post_condition": "STR is PENDING" }
    },
    {
      "operation_id": "str_advance",
      "domain": "str",
      "action": "advance",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Advance STR from PENDING to IN_PROGRESS — signals testing design has begun.",
      "inputs": [],
      "outputs": [
        { "name": "str_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STR must be PENDING" }
      ],
      "gating": { "pre_condition": "STR is PENDING", "post_condition": "STR is IN_PROGRESS" }
    },
    {
      "operation_id": "str_complete",
      "domain": "str",
      "action": "complete",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Mark STR as COMPLETE — test report finished, eligible for lock.",
      "inputs": [],
      "outputs": [
        { "name": "str_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STR must be IN_PROGRESS" }
      ],
      "gating": { "pre_condition": "STR is IN_PROGRESS", "post_condition": "STR is COMPLETE" }
    },
    {
      "operation_id": "str_lock",
      "domain": "str",
      "action": "lock",
      "level": "semantic",
      "role": "ant",
      "mode": "strict",
      "description": "Lock STR. Auto-cascades IMPL and WALK to LOCKED at same version if they are COMPLETE/IMPLEMENTED.",
      "inputs": [],
      "outputs": [
        { "name": "str_locked_state", "type": "state_transition" },
        { "name": "impl_autolock", "type": "state_transition" },
        { "name": "walk_autolock", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "STR must be COMPLETE" },
        { "type": "audit_policy", "rule": "Audit policy for str must be satisfied OR audit_gate override active" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": {
        "pre_condition": "STR is COMPLETE AND audit policy satisfied",
        "post_condition": "STR is LOCKED; IMPL and WALK at same version auto-locked if COMPLETE/IMPLEMENTED"
      }
    },
    {
      "operation_id": "str_list",
      "domain": "str",
      "action": "list",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "List all registered STRs and their lifecycle states.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": null }
    },
    {
      "operation_id": "impl_new",
      "domain": "impl",
      "action": "new",
      "level": "semantic",
      "role": "cdc",
      "mode": "strict",
      "description": "Create new IMPL (Pre-Implementation Plan) or WALK (post-execution walkthrough) document. Requires WO+STRAT locked AND same-version ANT-STR exists.",
      "inputs": [
        { "name": "type", "source": "option", "required": false, "values": ["impl", "walk"] }
      ],
      "outputs": [
        { "name": "impl_or_walk_document", "type": "document" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "WO+STRAT must be LOCKED" },
        { "type": "gate", "rule": "STR at same version must exist (PENDING/IN_PROGRESS/COMPLETE)" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": {
        "pre_condition": "WO is LOCKED AND STRAT is LOCKED AND STR version exists",
        "post_condition": "IMPL or WALK is PENDING"
      }
    },
    {
      "operation_id": "impl_complete",
      "domain": "impl",
      "action": "complete",
      "level": "semantic",
      "role": "cdc",
      "mode": "strict",
      "description": "Mark IMPL or WALK document as COMPLETE. Eligible for auto-lock when STR locks.",
      "inputs": [
        { "name": "file", "source": "option", "required": false }
      ],
      "outputs": [
        { "name": "impl_or_walk_state_entry", "type": "state_transition" },
        { "name": "gate_event", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "gate", "rule": "Document must be PENDING or IN_PROGRESS (not LOCKED)" },
        { "type": "block_gate", "rule": "No active cascade block on target version" }
      ],
      "gating": { "pre_condition": "IMPL or WALK is PENDING or IN_PROGRESS", "post_condition": "IMPL or WALK is COMPLETE" }
    },
    {
      "operation_id": "audit_record",
      "domain": "audit",
      "action": "record",
      "level": "semantic",
      "role": "any",
      "mode": "strict",
      "description": "Record an audit verdict (APPROVED, CONDITIONAL_APPROVAL, REJECTED) against an artifact.",
      "inputs": [
        { "name": "actor", "source": "option", "required": true },
        { "name": "verdict_flag", "source": "option", "required": true, "values": ["--approve", "--conditional", "--reject"] },
        { "name": "note", "source": "option", "required": false }
      ],
      "outputs": [
        { "name": "audit_record", "type": "log_entry" }
      ],
      "constraints": [
        { "type": "block_gate", "rule": "No active cascade block on artifact when verdict is --approve" }
      ],
      "gating": { "pre_condition": "artifact exists in document_states", "post_condition": "audit record written" }
    },
    {
      "operation_id": "audit_list",
      "domain": "audit",
      "action": "list",
      "level": "read_only",
      "role": "any",
      "mode": "any",
      "description": "List audit records, optionally filtered by artifact, actor, or verdict.",
      "inputs": [],
      "outputs": [],
      "constraints": [],
      "gating": { "pre_condition": "project exists", "post_condition": null }
    },
    {
      "operation_id": "audit_status",
